// -----------------------------------------------------------------------------
// tellovoice ESP32-S3 firmware configuration.
//
// Copy this file to `config.h` (same directory) and fill in your values, OR
// pass the same names as -D build flags in platformio.ini. Anything left unset
// falls back to the placeholder defaults compiled into main.cpp.
//
//   cp src/config.h.example src/config.h   # then edit src/config.h
//
// config.h is intentionally NOT committed (add it to .gitignore) so secrets
// stay out of the repo.
// -----------------------------------------------------------------------------
#pragma once

// ---- WiFi STA (phone hotspot — for internet / backend) --------------------
// MUST be a 2.4 GHz network. See README.md.
#define WIFI_SSID   "YOUR_HOTSPOT_SSID"
#define WIFI_PASS   "YOUR_HOTSPOT_PASSWORD"

// ---- Network mode ----------------------------------------------------------
// 0 = STA only : ESP32 + Tello both join the phone hotspot (Tello via
//                `ap <phoneSSID> <pass>`). Relies on hotspot client-to-client.
// 1 = AP only  : ESP32 is a standalone AP for the Tello. No internet / no voice.
// 2 = AP + STA : ESP32 runs its own AP (Tello joins it) AND joins the phone
//                hotspot for the backend. Recommended — predictable Tello IP,
//                no hotspot broadcast/isolation issues. (verified working)
#define NET_MODE    2

// ---- WiFi AP (local network for Tello; used when NET_MODE is 1 or 2) --------
// The Tello joins this via a one-time `ap TelloBridge tellovoice` (sent while
// connected to the Tello's own TELLO-XXXXXX / RMTT-XXXXXX WiFi). SSID must be
// alphanumeric (Tello limitation). Password >= 8 chars for WPA2.
#define AP_SSID     "TelloBridge"
#define AP_PASS     "147258369"        // fixed; not editable via the config portal
#define AP_CHANNEL  6                  // 1-13, quiet 2.4 GHz channel

// ---- Backend WebSocket (outbound / dial-out) -------------------------------
// Points at the deployed Dokploy backend. Uses wss on 443 (Let's Encrypt).
#define WS_HOST     "drone.xenv.cc"   // host only, no scheme/path
#define WS_PORT     443                // 443 for wss, 8080 for local ws
#define WS_PATH     "/ws/device"       // fixed by the backend
#define WS_USE_TLS  1                  // 1 = wss (beginSSL), 0 = plain ws

// ---- Video relay (backend ingest for ArUco tracking) -----------------------
// Where the ESP32 relays Tello's raw UDP video stream (received on Tello's own
// fixed port 11111) TO. Same host as WS_HOST — it's the same backend.
#define VIDEO_HOST  "drone.xenv.cc"   // host only, no scheme/path
#define VIDEO_PORT  8890               // matches backend config.videoPort default

// ---- Device identity (sent in the hello frame) -----------------------------
#define DEVICE_ID    "tello-esp32-01"
#define DEVICE_TOKEN "dev-device-token"          // must match backend DEVICE_TOKEN
#define FW_VERSION   "esp32s3-tello-relay/1.0.0"

// ---- RGB status LED (WS2812/NeoPixel) --------------------------------------
// Most generic ESP32-S3 devkits wire the addressable LED to GPIO48 (some 38).
// If the LED stays dark or shows wrong colors, try LED_PIN 38. Set LED_ENABLE 0
// if your board has no addressable LED.
#define LED_ENABLE     1
#define LED_PIN        48
#define LED_BRIGHTNESS 30             // 0-255; all states use this brightness
